{
  "name": "gdlxp-pipeline",
  "version": "0.1.0",
  "description": "AI-powered event aggregation pipeline for GDL XP.",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "migrate": "tsx --env-file-if-exists=.env src/db/migrate.ts",
    "seed": "tsx --env-file-if-exists=.env src/db/seed.ts"
  },
  "keywords": [
    "events",
    "aggregation",
    "pipeline",
    "express",
    "postgres"
  ],
  "author": "Adnan Bucio",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
